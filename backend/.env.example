# ── LUPU Backend Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development   # 'production' in prod — disables OTP console logs, enables CORS whitelist

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017/lupu
# Atlas (production):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lupu?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# PRODUCTION: Must be a 64+ character random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# If not set, defaults to localhost dev ports.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Leave as placeholder to enable mock payment mode in development.
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
