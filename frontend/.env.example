# ── LUPU Frontend Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── API ───────────────────────────────────────────────────────────────────────
# In development with Vite proxy configured, use /api (relative).
# In production, set to your deployed backend URL.
VITE_API_URL=/api

# ── Firebase ──────────────────────────────────────────────────────────────────
# Required for: Firestore (notifications, reviews, favorites) and Storage (uploads).
# Firebase Auth is NOT used — LUPU uses OTP → JWT via the Express backend.
# Get these values from the Firebase Console → Project Settings → Your apps.
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Public key only (safe to expose in client bundle).
# Leave as placeholder to use mock payment mode in development.
VITE_RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
